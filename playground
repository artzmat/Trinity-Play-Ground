#!/usr/bin/env bash
# playground - Fire up Left, Right, and Center terminals with watch windows
# Part of PCaC-Playgrounds three-persona setup.
#
# When you enter the term "playground" in Center Grok (the central orchestrator shell),
# this fires the full three terminals:
#   - Left: small/minimized konsole (960x600 centered) on Left monitor (DP-3) with tmux watch (top) + Left Grok chat (bottom)
#   - Right: small/minimized konsole (960x600 centered) on Right monitor (DP-2) with tmux watch (top) + Right Grok chat (bottom)
#   - Center: small/minimized konsole window (960x600 centered) on Center monitor (HDMI-A-1) with tmux split to see both chats + status (pc pin 1566894405)
#
# Run from Center terminal. Optional [user-label] for "User cursor:" (e.g. for remote/LAN-party cursors).
# All launches use the shared pcac_launch_playground helper (logs include pin marker).
#
# Also works as: grok-center playground [label]

set -euo pipefail

REPO_DIR="/data/PCaC-Playgrounds"
source "$REPO_DIR/scripts/lib/common.sh"

if [[ "${1-}" == "--help" || "${1-}" == "-h" ]]; then
  echo "Usage: playground [user-label]"
  echo "From Center Grok: fire up Left, Right, and Center terminals with watch windows."
  echo "  Left  (DP-3): *small/minimized* watch + chat box (960x600 centered window) for Left Grok persona"
  echo "  Right (DP-2): *small/minimized* watch + chat box (960x600 centered window) for Right Grok persona"
  echo "  Center (HDMI-A-1): *small/minimized* split view of both + status (960x600 centered window; includes pc pin 1566894405)"
  echo
  echo "Optional user-label sets the 'User cursor' in headers/titles/logs (for future remote users)."
  echo "Examples:"
  echo "  playground"
  echo "  playground alice"
  echo "  grok-center playground bob"
  exit 0
fi

label="${1:-$(whoami)}"

echo "Entering 'playground' in center grok: firing Left + Right + Center watch terminals (label=$label) | pc pin 1566894405"
pcac_launch_playground "$label"
