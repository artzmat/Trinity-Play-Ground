# Copy relevant sections to ~/.grok/config.toml after LM Studio server is running.
# Get model id: curl -s http://127.0.0.1:1234/v1/models

[model.lmstudio-qwen]
model = "REPLACE_WITH_ID_FROM_/v1/models"
base_url = "http://127.0.0.1:1234/v1"
name = "Qwen2.5-14B Q4 (Left/Right local)"
api_key = "lm-studio"
api_backend = "chat_completions"
context_window = 32768
max_completion_tokens = 4096

# Center — Command-R (slot :3)
# As of 2026-06-07, Center runs on local Command-R (slot :3) — not cloud
# Grok. Load `c4ai-command-r-08-2024` onto slot :3 before invoking
# `center-c "..."`. See personas/center/SYSTEM.md,
# personas/center/TNMP-Cline-Rules.md, config/model-assignments.md, and
# docs/center-command-r-20260607.md for the full setup.
# Context 4096 is the 400-error-safe value; raise to 8192 once stable.
[model.lmstudio-command-r]
model = "REPLACE_WITH_ID_FROM_/v1/models"   # the Command-R id from /v1/models
base_url = "http://127.0.0.1:1234/v1"
name = "Command-R 08-2024 (Center, slot :3)"
api_key = "lm-studio"
api_backend = "chat_completions"
context_window = 4096    # raise to 8192 only after a few stable sessions
max_completion_tokens = 2048

# [models]
# default = "lmstudio-command-r"   # Center is the default as of 2026-06-07
# # left/right route to Qwen for chat; use -m lmstudio-qwen when calling
# # the local side personas
# left = "lmstudio-qwen"
# right = "lmstudio-qwen"
