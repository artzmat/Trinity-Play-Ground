# Copy relevant sections to ~/.grok/config.toml after LM Studio server is running.
# Get model id: curl -s http://127.0.0.1:1234/v1/models

[model.lmstudio-qwen]
model = "REPLACE_WITH_ID_FROM_/v1/models"
base_url = "http://127.0.0.1:1234/v1"
name = "Qwen2.5-14B Q4 (Left/Right local)"
api_key = "lm-studio"
api_backend = "chat_completions"
context_window = 32768
max_completion_tokens = 4096

# [models]
# default = "grok-build"   # keep Center on cloud; use -m lmstudio-qwen for local tests