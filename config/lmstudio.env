# LM Studio local server (Phase 2+)
# List ids: curl -s http://127.0.0.1:1234/v1/models | jq -r '.data[].id'
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MAX_TOKENS=512

# Side-specific for better persona fit (Left: analytical/structured/chill -> lower temp, more tokens for reasoning)
LMSTUDIO_TEMPERATURE_LEFT=0.3
LMSTUDIO_MAX_TOKENS_LEFT=2048
LMSTUDIO_TEMPERATURE_RIGHT=0.75
LMSTUDIO_MAX_TOKENS_RIGHT=768

# Default (if side-specific not set)
LMSTUDIO_MODEL=qwen/qwen2.5-coder-14b

# Two-instance setup (recommended on 24GB VRAM) — Left + Right only; unload :3 in LM Studio UI
LMSTUDIO_MODEL_LEFT=qwen/qwen2.5-coder-14b
LMSTUDIO_MODEL_RIGHT=qwen/qwen2.5-coder-14b:2
# Do not use :3 for PCaC unless testing manually — unload third tab to save VRAM