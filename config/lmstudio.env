# LM Studio local server
# List ids: curl -s http://127.0.0.1:1234/v1/models | jq -r '.data[].id'
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_MAX_TOKENS=512

# Side-specific for better persona fit (Left: analytical/structured/chill -> lower temp, more tokens for reasoning)
LMSTUDIO_TEMPERATURE_LEFT=0.3
LMSTUDIO_MAX_TOKENS_LEFT=2048
LMSTUDIO_TEMPERATURE_RIGHT=0.75
LMSTUDIO_MAX_TOKENS_RIGHT=768

# Default (if side-specific not set)
LMSTUDIO_MODEL=qwen/qwen2.5-coder-14b

# Two-instance setup (recommended on 24GB VRAM) — Left + Right only;
# unload :3 in LM Studio UI to free VRAM for chat.
LMSTUDIO_MODEL_LEFT=qwen/qwen2.5-coder-14b
LMSTUDIO_MODEL_RIGHT=qwen/qwen2.5-coder-14b:2

# === Center (Command-R) — slot :3 ===
# As of 2026-06-07, Center is local Command-R (not cloud Grok). Load
# `c4ai-command-r-08-2024` onto slot :3 only when you intend to drive
# `center-c "..."` work in Cline.
# See personas/center/SYSTEM.md, personas/center/TNMP-Cline-Rules.md,
# config/model-assignments.md, and docs/center-command-r-20260607.md.
# Recommended sampling: Context 4096, Temp 0.35, Top-P 0.9, Max 2048.
# IMPORTANT: use the exact id returned by `curl -s http://127.0.0.1:1234/v1/models`.
# The provider-prefixed form `cohereforai.c4ai-command-r-08-2024` is what
# LM Studio serves. The un-prefixed `c4ai-command-r-08-2024` returns 400
# "Invalid model identifier" (verified 2026-06-07). See docs/center-command-r-20260607.md.
LMSTUDIO_MODEL_CENTER=cohereforai.c4ai-command-r-08-2024
LMSTUDIO_TEMPERATURE_CENTER=0.35
LMSTUDIO_MAX_TOKENS_CENTER=2048
LMSTUDIO_CONTEXT_CENTER=4096

# === Legacy env vars (deprecated 2026-06-07) ===
# The following Tool Agent vars were renamed when the Tool Agent role was
# absorbed into Center. They are kept here as comments for one release
# cycle so existing scripts keep working until they are updated. Remove
# in a later commit.
# LMSTUDIO_MODEL_TOOL_AGENT=c4ai-command-r-08-2024
# LMSTUDIO_TEMPERATURE_TOOL_AGENT=0.4
# LMSTUDIO_MAX_TOKENS_TOOL_AGENT=4096
# LMSTUDIO_CONTEXT_TOOL_AGENT=16384
