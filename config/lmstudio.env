# LM Studio Environment Configuration
# This file contains model assignments for Left, Right, and Center personas

# Base URL for LM Studio API
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# Model assignments for each persona
# Left-Brain: qwen2.5-coder-14b (Q4_K_M) - Slot :1
LMSTUDIO_MODEL_LEFT=qwen/qwen2.5-coder-14b

# Right-Brain: qwen2.5-coder-14b (Q4_K_M) - Slot :2
LMSTUDIO_MODEL_RIGHT=qwen/qwen2.5-coder-14b:2

# Center: c4ai-command-r-08-2024 (GGUF) - Slot :3
LMSTUDIO_MODEL_CENTER=cohereforai.c4ai-command-r-08-2024

# Additional settings for each persona
# Left-Brain specific settings
LEFT_TEMPERATURE=0.3
LEFT_TOP_P=0.85
LEFT_REPETITION_PENALTY=1.1

# Right-Brain specific settings
RIGHT_TEMPERATURE=0.75
RIGHT_TOP_P=0.93
RIGHT_MIN_P=0.08
RIGHT_REPETITION_PENALTY=1.15
RIGHT_Mirostat=2
RIGHT_Mirostat_Tau=5

# Center specific settings
CENTER_TEMPERATURE=0.35
CENTER_TOP_P=0.9
