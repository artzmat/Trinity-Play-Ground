# === PCaC /data discipline ===
# All heavy state, VMs, containers, media, logs live under /data (outside or
# alongside this repo). This .gitignore protects the control repo itself.

# VM / libvirt images and metadata (we keep only XML exports here)
*.qcow2
*.img
*.raw
var/
run/
tmp/

# Docker / container artifacts
docker-compose.override.yml
.docker/

# Python / general
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Logs and local env (covers anything committed inside the tree)
*.log
.env
.env.local
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# PCaC runtime state (if you ever create inside the repo tree)
pcac-state/
state/
*.pcac
