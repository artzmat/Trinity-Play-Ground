#!/usr/bin/env bash
# grok-center
# Launches the Center Orchestrator Grok chat viewer (tails Left and Right chats)
# Part of PCaC three-persona setup.

set -euo pipefail

REPO_DIR="/data/PCaC-Playgrounds"
source "$REPO_DIR/scripts/lib/common.sh"

echo "Starting Center Orchestrator Grok chat viewer..."
echo "This shows messages from Left Grok and Right Grok personas."
echo "To respond to Left: use 'pcac_post_chat left \"Center Grok (to Left)\" \"your response\"' (after sourcing lib/common.sh)"
echo "Same for right. Or edit the chat logs directly."
echo ""

exec "$REPO_DIR/scripts/center-chat-view.sh"