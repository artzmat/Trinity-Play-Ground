#!/usr/bin/env bash
# grok-center
# Launches the Center Orchestrator Grok chat viewer (tails Left and Right chats)
# Part of PCaC three-persona setup.

set -euo pipefail

REPO_DIR="/data/PCaC-Playgrounds"
source "$REPO_DIR/scripts/lib/common.sh"

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
  echo "Usage: grok-center"
  echo "Launches a dedicated Center Orchestrator terminal (tmux split) to see both Left and Right chats."
  echo "Use pcac_post_chat from lib/common.sh (or edit logs) to respond as Center Grok."
  echo "This is the 'Center terminal to see both'."
  exit 0
fi

echo "Starting Center Orchestrator terminal to see both Left and Right..."

# Launch in a konsole on the Center monitor geometry (1920x1080+1920+0)
# with the tmux split view for monitoring both personas.
konsole --qwindowgeometry 1920x1080+1920+0 --title "PCaC-Center-Monitor-Both" -e "$REPO_DIR/scripts/center-tmux.sh" &
PID=$!
pcac_log INFO "Opened Center monitor terminal (geom 1920x1080+1920+0, pid $PID)"
echo "  Title: PCaC-Center-Monitor-Both (tmux split: Left Chat | Right Chat)"
echo "  Ctrl-b arrows to switch panes."
echo "  To respond: source lib/common.sh then pcac_post_chat left/right ..."
echo "  (The old combined tail viewer is still available via center-chat-view.sh if preferred.)"