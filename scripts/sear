#!/bin/bash
# sear - Private search via local SearXNG (localhost only, for low-impact / sensitive work)
# Usage: sear your search terms here
# This is the preferred research tool for the PCaC personas (local, private, no cloud).

set -euo pipefail

query="$*"
if [[ -z "$query" ]]; then
  echo "Usage: sear <search terms>"
  exit 1
fi

curl -s "http://127.0.0.1:8080/search?q=${query// /+}&format=json" \
| jq -r '.results[] | "\(.title)\n\(.url)\n\(.content[0:280])...\n---"' 2>/dev/null || echo "SearXNG not responding or no results. Try again or use web_search if needed."