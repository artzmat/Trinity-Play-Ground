#!/usr/bin/env bash
# grok-left [optional-user-label]
# Launches/attaches the Left Grok persona terminal (watch top + full Grok TUI as Left-Brain persona bottom)
# on the Left monitor.
# Part of the simplified three-grok-cli setup (no LM Studio required for core personas).
# The Left Grok is a full cloud Grok instance with Left-Brain persona baked in.

set -euo pipefail

REPO_DIR="/data/PCaC-Playgrounds"
source "$REPO_DIR/scripts/lib/common.sh"

if [[ "${1-}" == "--help" || "${1-}" == "-h" ]]; then
  echo "Usage: grok-left [user-label]"
  echo "Launches the Left Grok persona (tmux watch + chat in *small/minimized* 960x600 window on Left monitor DP-3)."
  echo "Optional user-label for remote 'User cursor' distinction."
  exit 0
fi

USER_LABEL="${1:-$(whoami)}"

echo "Starting Left Grok persona for user: $USER_LABEL (small/minimized window)"
pcac_open_watch_left "$USER_LABEL"