#!/usr/bin/env bash
# grok-left [optional-user-label]
# Launches/attaches the Left Grok persona terminal (watch + chat tmux on Left monitor)
# Part of PCaC three-persona setup: Left Grok, Right Grok, Center Orchestrator Grok.

set -euo pipefail

REPO_DIR="/data/PCaC-Playgrounds"
source "$REPO_DIR/scripts/lib/common.sh"

if [[ "${1-}" == "--help" || "${1-}" == "-h" ]]; then
  echo "Usage: grok-left [user-label]"
  echo "Launches the Left Grok persona (tmux watch + chat on Left monitor DP-3)."
  echo "Optional user-label for remote 'User cursor' distinction."
  exit 0
fi

USER_LABEL="${1:-$(whoami)}"

echo "Starting Left Grok persona for user: $USER_LABEL"
pcac_open_watch_left "$USER_LABEL"