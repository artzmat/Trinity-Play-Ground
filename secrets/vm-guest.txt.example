# PCaC VM guest credentials — COPY to vm-guest.txt and fill in (chmod 600)
# Format: vm-name<TAB or spaces>username<TAB>password-note-or-password
# Use a dedicated guest password per tier — NOT your host passwd.

# Tier: playground (entertainment, right monitor, disposable snapshots)
playground        guest     REPLACE_ME_playground_guest
right-guest       guest     REPLACE_ME_legacy_alias

