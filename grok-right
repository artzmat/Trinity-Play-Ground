#!/usr/bin/env bash
# grok-right [optional-user-label]
# Launches/attaches the Right Grok persona terminal (watch top + full Grok TUI as Right-Brain persona bottom)
# on the Right monitor.
# Part of the simplified three-grok-cli setup (no LM Studio required).
# Full cloud Grok with Right-Brain persona.

set -euo pipefail

REPO_DIR="/data/PCaC-Playgrounds"
source "$REPO_DIR/scripts/lib/common.sh"

if [[ "${1-}" == "--help" || "${1-}" == "-h" ]]; then
  echo "Usage: grok-right [user-label]"
  echo "Launches the Right Grok persona (tmux watch + chat in *small/minimized* 960x600 window on Right monitor DP-2)."
  echo "Optional user-label for remote 'User cursor' distinction."
  exit 0
fi

USER_LABEL="${1:-$(whoami)}"

echo "Starting Right Grok persona for user: $USER_LABEL (small/minimized window)"
pcac_open_watch_right "$USER_LABEL"