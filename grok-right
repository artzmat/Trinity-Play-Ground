#!/usr/bin/env bash
# grok-right [optional-user-label]
# Launches/attaches the Right Grok persona terminal (watch + chat tmux on Right monitor)
# Part of PCaC three-persona setup: Left Grok, Right Grok, Center Orchestrator Grok.

set -euo pipefail

REPO_DIR="/data/PCaC-Playgrounds"
source "$REPO_DIR/scripts/lib/common.sh"

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
  echo "Usage: grok-right [user-label]"
  echo "Launches the Right Grok persona (tmux watch + chat on Right monitor DP-2)."
  echo "Optional user-label for remote 'User cursor' distinction."
  exit 0
fi

USER_LABEL="${1:-$(whoami)}"

echo "Starting Right Grok persona for user: $USER_LABEL"
pcac_open_watch_right "$USER_LABEL"